# ─── Database ───
POSTGRES_USER=moimio
POSTGRES_PASSWORD=moimio_dev
POSTGRES_DB=moimio
DB_PORT=6122

# ─── Backend ───
DATABASE_URL=postgresql+asyncpg://moimio:moimio_dev@db:5432/moimio
SECRET_KEY=change-me-in-production-use-64-chars-minimum-random-string-here
LOG_LEVEL=DEBUG
CORS_ORIGINS=http://localhost:6120
RATE_LIMIT_REGISTRATION=10
BACKEND_PORT=6121

# ─── Frontend ───
VITE_API_URL=http://localhost:6121
FRONTEND_PORT=6120

# ─── App ───
# APP_URL is no longer needed. Email links (registration confirmation,
# password reset) are derived from the incoming request, so whatever
# domain a user is on is the domain they get in their email — no
# configuration needed. A lingering APP_URL=... line in an existing
# .env is silently ignored and can be deleted.

# ─── Email (SMTP) ─────────────────────────────────────────────────
# Moimio sends three transactional emails: registration confirmation,
# post-confirmation receipt, and password reset.
#
# Leave SMTP_HOST or SMTP_USER empty to run without email — the app
# functions normally and logs "email_skipped" in place of sends.
# Useful for local development.
#
# Common providers that work out of the box:
#   - Zoho:    smtp.zoho.eu          : 587 (TLS) — generate app password at
#              https://accounts.zoho.eu/home#security/app_passwords
#   - Gmail:   smtp.gmail.com        : 587 (TLS) — needs an app password
#              (requires 2FA enabled on the Google account)
#   - Brevo:   smtp-relay.brevo.com  : 587 (TLS) — free tier covers most
#              small-church volumes
#   - SMTP2GO: mail.smtp2go.com      : 587 (TLS) — pay-as-you-go, free
#              tier available
#
# SMTP_FROM_NAME appears as the display name in the recipient's inbox
# (e.g. "Your Church Events" <events@yourchurch.org>).
#
# After deploying, test from the UI: Event Settings → Email → Send test
# email. The test lands in the admin's inbox and shows exactly which
# From / Reply-to / SMTP server was used.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Moimio
SMTP_TLS=true
SMTP_SSL=false

# ─── Capability flags (v1.0.0g) ───────────────────────────────────
# Capabilities are framed in terms of features, not commercial tiers —
# CE does not know about pricing. Default ON for every self-hoster.
#
# FEATURE_ALLOCATION: when false, the allocation engine and its
# /api/allocations endpoints are excluded entirely. Use this for a
# registration-only deployment (e.g. small events that don't need
# room/group assignment).
#
# FEATURE_OUTBOUND_WEBHOOKS: when false, the outbound webhook subsystem
# (admin UI, /api/webhooks endpoints, scheduled retry/prune jobs) is
# disabled. Use this if you don't want to expose webhook integration.
FEATURE_ALLOCATION=true
FEATURE_OUTBOUND_WEBHOOKS=true

# ─── Create-event confirmation (v1.0.0h) ──────────────────────────
# Optional. When true, an "are you sure?" dialog appears before an
# admin completes event creation, showing what will be charged. CE
# default is false — self-hosters typically have no charge model, so
# the dialog stays out of the way.
#
# When set to true, the three EVENT_CHARGE_* / BILLING_CARD_LAST4
# values below get rendered in the dialog. Missing values fall back
# gracefully (e.g. an empty BILLING_CARD_LAST4 just changes the
# wording from "card ending 4242" to "card on file").
#
# Typical use case: a SaaS provider running Moimio for a tenant on a
# per-event plan, where the admin should see the charge before
# committing.
FEATURE_CREATE_EVENT_CONFIRMATION=false

# Numeric amount (as a string). Format-agnostic — the frontend's
# Intl.NumberFormat localises this for display, so don't include
# currency symbols. Example: 120 (not "€120", not "$120.00").
EVENT_CHARGE_AMOUNT=

# ISO 4217 currency code. Example: EUR, GBP, KRW, USD.
EVENT_CHARGE_CURRENCY=

# Last 4 digits of the card on file. NEVER the full card number —
# the full PAN must never touch CE config. SaaS reads it from
# Paddle's response and writes only the last 4 here.
BILLING_CARD_LAST4=

# ─── Tenant identity (v1.0.0h) ────────────────────────────────────
# Optional. When set, this value is included as a top-level
# `tenant_id` field on every outbound webhook payload. When blank,
# the field is omitted entirely from payloads — no clutter for
# self-hosters who don't need it.
#
# Use case: if you're forwarding events from multiple Moimio
# installations into a single downstream system (your own bus, or a
# SaaS provider managing this install), set a short identifier here
# so the receiver can tell installations apart. The value is opaque
# to Moimio — any short string works (e.g. "main-church",
# "youth-camp-2026").
#
# Leave blank for a normal single-install self-host.
MOIMIO_TENANT_ID=

# ─── Automatic webhook configuration (v1.0.0g) ────────────────────
# Optional. When BOTH variables are set AND no SaaS-managed webhook
# endpoint exists yet, Moimio auto-registers an endpoint at first boot
# subscribing to all event types. Useful for deployment automation:
# point Moimio at your central event bus without admin clicks.
#
# Leave empty if you're running a normal self-host without automation.
# Self-hosters configure webhooks through the admin UI instead.
MOIMIO_WEBHOOK_URL=
MOIMIO_WEBHOOK_SECRET=

# How many days of outbound webhook delivery history to retain. The
# log is pruned daily at 03:00 UTC. 30 days is enough for any practical
# debugging conversation while keeping the table small.
WEBHOOK_DELIVERY_RETENTION_DAYS=30
