{
  "name": "moimio-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "python3 scripts/validate-i18n-keys.py --quiet && vite build",
    "preview": "vite preview",
